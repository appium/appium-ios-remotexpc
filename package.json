{
  "name": "appium-ios-remotexpc",
  "version": "5.4.0",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./build/src/index.js",
      "types": "./build/src/index.d.ts"
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "clean:build": "rimraf ./build",
    "build:es": "tsc",
    "build": "run-s clean:* build:es build:test-assets",
    "lint": "eslint src scripts",
    "prepare": "husky && npm run build",
    "format": "prettier --write \"{src,test}/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint src scripts --fix",
    "test": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/**/*.js\"",
    "test:all": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/unit/**/*.js\" \"build/test/integration/**/*.js\"",
    "test:tunnel": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/tunnel-test.js\"",
    "test:pair-record": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/read-pair-record-test.js\"",
    "test:diagnostics": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/diagnostics-test.js\"",
    "test:notification": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/notification-proxy-test.js\"",
    "test:hid-indigo": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/hid-indigo-test.js\"",
    "test:app-service": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/app-service-test.js\"",
    "test:image-mounter": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/mobile-image-mounter-test.js\"",
    "test:mobile-config": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/mobile-config-test.js\"",
    "test:springboard": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/springboard-service-test.js\"",
    "test:unit": "npm run build && NODE_ENV=test node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=120000 \"build/test/unit/**/*.js\"",
    "test:discovery": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=30000 \"build/test/integration/mdns-discovery-test.js\"",
    "tunnel-creation": "sudo node scripts/tunnel-creation.mjs",
    "pair-appletv": "sudo node scripts/pair-appletv.mjs",
    "start-appletv-tunnel": "sudo node scripts/start-appletv-tunnel.mjs",
    "test:webinspector": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/webinspector-test.js\"",
    "test:misagent": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/misagent-service-test.js\"",
    "test:afc": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/afc-test.js\"",
    "test:afc-push-perf": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=180000 \"build/test/integration/afc-push-performance-test.js\"",
    "test:afc-tunnel-stability": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=1800000 \"build/test/integration/afc-tunnel-stability-test.js\"",
    "test:lockdown-tunnel": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/lockdown-tunnel-test.js\"",
    "test:crash-reports": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/crash-reports-test.js\"",
    "test:house-arrest": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/house-arrest-test.js\"",
    "test:installation-proxy": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/installation-proxy-test.js\"",
    "test:installation-workflow": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=300000 \"build/test/integration/afc-installation-workflow-test.js\"",
    "test:zipconduit-install": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=600000 \"build/test/integration/zipconduit-install-test.js\"",
    "test:power-assertion": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/power-assertion-test.js\"",
    "test:dvt": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt-service-test.js\"",
    "test:dvt:graphics": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/graphics-test.js\"",
    "test:dvt:location-simulation": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/location-simulation-test.js\"",
    "test:dvt:condition-inducer": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/condition-inducer-test.js\"",
    "test:dvt:screenshot": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/screenshot-test.js\"",
    "test:dvt:device-info": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/device-info-test.js\"",
    "test:dvt:applist": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/app-listing-test.js\"",
    "test:dvt:notification": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/notifications-test.js\"",
    "test:dvt:network-monitor": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/network-monitor-test.js\"",
    "test:dvt:sysmontap": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/dvt_instruments/sysmontap-test.js\"",
    "test:dvt:process-control": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=60000 \"build/test/integration/process-control-test.js\"",
    "test:testmanagerd": "npm run build && node --import ./build/test/helpers/node-test-globals.js --test --test-timeout=120000 \"build/test/integration/testmanagerd-test.js\"",
    "test:tunnel-creation": "sudo node scripts/tunnel-creation.mjs",
    "test:tunnel-creation:lsof": "sudo node scripts/tunnel-creation.mjs --keep-open",
    "build:test-assets": "node scripts/copy-test-assets.mjs"
  },
  "keywords": [],
  "author": "Appium Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appium/appium-ios-remotexpc.git"
  },
  "bugs": {
    "url": "https://github.com/appium/appium-ios-remotexpc/issues"
  },
  "description": "",
  "devDependencies": {
    "@appium/eslint-config-appium-ts": "^3.0.0",
    "@appium/tsconfig": "^1.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/async-lock": "^1.4.2",
    "@types/node": "^25.0.2",
    "@types/sinon": "^21.0.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "esmock": "^2.7.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.2",
    "sinon": "^22.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@appium/strongbox": "^1.1.2",
    "@appium/support": "^7.2.2",
    "@xmldom/xmldom": "^0.x",
    "appium-ios-tuntap": "^1.0.0",
    "async-lock": "^1.4.1",
    "axios": "^1.15.1",
    "commander": "^14.0.1",
    "minimatch": "^10.1.1",
    "node-devicectl": "^1.2.0",
    "npm-run-all2": "^8.0.4",
    "path-to-regexp": "^8.3.0"
  },
  "files": [
    "src",
    "scripts",
    "build/src",
    "!.DS_Store",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
